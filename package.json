{
    "name": "image2-app-webui",
    "version": "0.2.0",
    "private": true,
    "scripts": {
        "predev": "prisma generate",
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "start:prod": "next start --hostname 0.0.0.0 --port 3000",
        "db:migrate": "prisma migrate deploy",
        "lint": "next lint",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:db": "vitest run --config vitest.db.config.ts",
        "test:db:setup": "prisma migrate deploy",
        "test:all": "vitest run && vitest run --config vitest.db.config.ts",
        "postinstall": "prisma generate",
        "prisma:generate": "prisma generate",
        "prisma:seed": "tsx prisma/seed.ts",
        "chatgpt:login": "tsx scripts/chatgpt-login.ts",
        "chatgpt:check": "tsx scripts/chatgpt-check.ts",
        "chatgpt:generate": "tsx scripts/chatgpt-generate.ts",
        "build:console": "cd console && npx -y pnpm@11.10.0 install --frozen-lockfile && npx -y pnpm@11.10.0 run build:antd && rm -rf ../public/console && cp -R apps/web-antd/dist ../public/console"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1084.0",
        "@prisma/client": "^5.22.0",
        "clsx": "^2.1.1",
        "lucide-react": "^0.468.0",
        "next": "^15.0.0",
        "playwright": "^1.49.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "sharp": "^0.34.5",
        "tailwind-merge": "^2.5.5"
    },
    "devDependencies": {
        "@types/node": "^22.10.1",
        "@types/react": "^19.0.1",
        "@types/react-dom": "^19.0.2",
        "autoprefixer": "^10.4.20",
        "eslint": "^9.16.0",
        "eslint-config-next": "^15.0.0",
        "postcss": "^8.4.49",
        "prisma": "^5.22.0",
        "tailwindcss": "^3.4.16",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2",
        "vitest": "^4.1.10"
    }
}

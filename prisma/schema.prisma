generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum GenerationStatus {
  QUEUED
  POLISHING
  GENERATING
  UPLOADING
  COMPLETED
  FAILED
  CANCELED
}

enum CreditTransactionType {
  GRANT
  FREEZE
  SPEND
  REFUND
  PURCHASE
  ADJUSTMENT
}

enum RechargeOrderStatus {
  PENDING
  PAID
  CANCELED
  EXPIRED
}

model User {
  id                 String              @id @default(cuid())
  email              String?             @unique
  phone              String?             @unique
  displayName        String?
  avatarUrl          String?
  passwordHash       String?
  role               UserRole            @default(USER)
  lastLoginAt        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  creditAccount      CreditAccount?
  generationJobs     GenerationJob[]
  uploadedImages     UploadedImage[]
  promptFavorites    PromptFavorite[]
  creditTransactions CreditTransaction[]
  rechargeOrders     RechargeOrder[]
  oauthAccounts      OAuthAccount[]
  subscription       Subscription?
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  email             String?
  displayName       String?
  avatarUrl         String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model EmailVerificationCode {
  id         String    @id @default(cuid())
  email      String
  purpose    String    @default("register")
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([email, purpose, createdAt])
  @@index([expiresAt])
  @@index([consumedAt])
}

model PromptCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0)
  prompts     Prompt[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Prompt {
  id             String           @id @default(cuid())
  categoryId     String?
  title          String
  slug           String           @unique
  summary        String
  promptZh       String
  promptEn       String
  negativePrompt String?
  coverUrl       String?
  sourceName     String?
  sourceUrl      String?
  authorName     String?
  licenseNote    String?
  viewCount      Int              @default(0)
  favoriteCount  Int              @default(0)
  weight         Int              @default(0)
  tags           PromptTag[]
  favorites      PromptFavorite[]
  category       PromptCategory?  @relation(fields: [categoryId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model PromptTag {
  id       String @id @default(cuid())
  promptId String
  name     String
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@index([name])
}

model PromptFavorite {
  id       String   @id @default(cuid())
  userId   String
  promptId String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt   Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, promptId])
}

model GenerationJob {
  id                String           @id @default(cuid())
  userId            String
  status            GenerationStatus @default(QUEUED)
  originalInput     String
  polishedPromptZh  String?
  polishedPromptEn  String?
  negativePrompt    String?
  ratio             String           @default("1:1")
  quality           String           @default("standard")
  imageCount        Int              @default(1)
  creditCost        Int              @default(0)
  errorMessage      String?
  provider          String           @default("openai")
  providerRequestId String?
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  images            GeneratedImage[]
  referenceImages   GenerationJobReferenceImage[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([userId, createdAt])
  @@index([status])
}

model UploadedImage {
  id            String                        @id @default(cuid())
  userId        String
  url           String
  thumbnailUrl  String?
  mimeType      String
  fileSize      Int
  width         Int?
  height        Int?
  purpose       String                        @default("reference")
  isDeleted     Boolean                       @default(false)
  user          User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobReferences GenerationJobReferenceImage[]
  createdAt     DateTime                      @default(now())

  @@index([userId, createdAt])
  @@index([purpose])
  @@index([isDeleted])
}

model GenerationJobReferenceImage {
  id        String        @id @default(cuid())
  jobId     String
  imageId   String
  sortOrder Int           @default(0)
  job       GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  image     UploadedImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([jobId, imageId])
  @@index([jobId, sortOrder])
  @@index([imageId])
}

model GeneratedImage {
  id              String        @id @default(cuid())
  jobId           String
  url             String
  thumbnailUrl    String?
  width           Int?
  height          Int?
  fileSize        Int?
  mimeType        String?
  seed            String?
  isPublic        Boolean       @default(false)
  isDeleted       Boolean       @default(false)
  publishedAt     DateTime?
  takenDownAt     DateTime?
  takenDownReason String?
  job             GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@index([isPublic, createdAt])
  @@index([isDeleted])
  @@index([publishedAt])
}

model CuratedGalleryImage {
  id              String   @id @default(cuid())
  title           String
  summary         String
  imageUrl        String
  thumbnailUrl    String?
  width           Int?
  height          Int?
  fileSize        Int?
  mimeType        String?
  ratio           String   @default("1:1")
  category        String   @default("其他")
  tags            String   @default("")
  promptZh        String
  promptEn        String?
  negativePrompt  String?
  provider        String   @default("curated")
  authorName      String   @default("造图台")
  sourceName      String?
  sourceUrl       String?
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  isDeleted       Boolean  @default(false)
  publishedAt     DateTime?
  takenDownAt     DateTime?
  takenDownReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@index([category])
  @@index([isDeleted])
  @@index([publishedAt])
}

model CreditAccount {
  id             String   @id @default(cuid())
  userId         String   @unique
  available      Int      @default(0)
  frozen         Int      @default(0)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CreditTransaction {
  id        String                @id @default(cuid())
  userId    String
  type      CreditTransactionType
  amount    Int
  balance   Int
  memo      String?
  jobId     String?
  orderId   String?
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime              @default(now())

  @@index([userId, createdAt])
}

model CreditPackage {
  id            String          @id @default(cuid())
  name          String
  description   String?
  credits       Int
  bonusCredits  Int             @default(0)
  priceCents    Int
  currency      String          @default("CNY")
  packageType   String          @default("RECHARGE")
  durationDays  Int             @default(0)
  sortOrder     Int             @default(0)
  isActive      Boolean         @default(true)
  orders        RechargeOrder[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([isActive, sortOrder])
}

model RechargeOrder {
  id                  String              @id @default(cuid())
  orderNo             String              @unique
  userId              String
  packageId           String?
  packageNameSnapshot String
  credits             Int
  bonusCredits        Int                 @default(0)
  packageType         String              @default("RECHARGE")
  durationDays        Int                 @default(0)
  amountCents         Int
  currency            String              @default("CNY")
  status              RechargeOrderStatus @default(PENDING)
  provider            String              @default("manual")
  paymentUrl          String?
  qrCodeUrl           String?
  providerTradeNo     String?
  providerPayload     String?
  notifyPayloadDigest String?
  notifiedAt          DateTime?
  capturedAt          DateTime?
  paymentMethod       String              @default("manual_transfer")
  paymentNote         String?
  paymentProofUrl     String?
  paymentProofName    String?
  paymentProofMimeType String?
  paymentProofSize    Int?
  submittedAt         DateTime?
  adminNote           String?
  paidAt              DateTime?
  expiresAt           DateTime?
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  package             CreditPackage?      @relation(fields: [packageId], references: [id], onDelete: SetNull)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([packageId])
  @@index([submittedAt])
  @@index([provider])
  @@index([providerTradeNo])
}

model Subscription {
  id          String   @id @default(cuid())
  userId      String   @unique
  packageId   String?
  packageName String
  startedAt   DateTime @default(now())
  expiresAt   DateTime
  lastOrderId String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([expiresAt])
}

model PaymentEvent {
  id              String   @id @default(cuid())
  provider        String
  eventType       String
  orderNo         String?
  providerTradeNo String?
  status          String   @default("RECEIVED")
  httpMethod      String?
  requestPath     String?
  payloadDigest   String?
  message         String?
  rawPayload      String?
  createdAt       DateTime @default(now())

  @@index([provider, createdAt])
  @@index([orderNo])
  @@index([status, createdAt])
}

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  isEncrypted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

# Database
POSTGRES_DB="image2_app"
POSTGRES_USER="image2_app"
POSTGRES_PASSWORD="replace-with-a-strong-database-password"
DATABASE_URL="postgresql://image2_app:replace-with-a-strong-database-password@postgres:5432/image2_app"

# 数据库集成测试专用库（仅本地开发/测试用）。设置后 `npm run test:db` 才会真正连库跑集成测试；
# 不设置则集成测试自动跳过（纯逻辑 `npm test` 不受影响）。
# 首次使用：`createdb image2_app_test` 建独立测试库，再执行 `DATABASE_URL=$DATABASE_URL_TEST npm run test:db:setup` 应用 schema。
# 示例：DATABASE_URL_TEST="postgresql://image2_app:replace-with-a-strong-database-password@localhost:5432/image2_app_test"
DATABASE_URL_TEST=""

# Public URL used by payment callbacks and admin diagnostics.
# Production example: https://image.example.com
APP_PORT="3000"
NEXT_PUBLIC_SITE_URL="http://127.0.0.1:3000"

# Session and encrypted setting secrets. Replace both before production.
AUTH_SECRET="replace-with-at-least-32-random-characters"
SETTINGS_ENCRYPTION_KEY="replace-with-at-least-32-random-characters"

# Initial admin bootstrap. Only used when the admin account does not exist.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="replace-with-a-strong-password"

# New user credit grant.
NEW_USER_INITIAL_CREDITS="0"

# Optional Redis placeholder. Current task queue is still in-process.
REDIS_URL="redis://localhost:6379"

# Optional browser path for ChatGPT Web provider on Windows/local deployment.
# Example: C:\Program Files\Google\Chrome\Application\chrome.exe
CHROME_EXECUTABLE_PATH=""

# Legacy/default model values. Runtime keys should be saved in Admin Settings where they are encrypted.
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-chat"
OPENAI_IMAGE_MODEL="gpt-image-2"
DEFAULT_GENERATION_PROVIDER="openai"

# OpenAI-compatible image provider fallback.
# Production multi-channel relays should be configured in Admin Settings.
# If no relay list is saved, the app falls back to OPENAI_API_KEY + OPENAI_IMAGE_MODEL + https://api.openai.com/v1.
OPENAI_API_KEY=""

# SMTP email fallback. Production values are recommended to be saved in Admin Settings.
EMAIL_SMTP_ENABLED="false"
EMAIL_SMTP_HOST=""
EMAIL_SMTP_PORT="465"
EMAIL_SMTP_SECURE="true"
EMAIL_SMTP_USER=""
EMAIL_SMTP_PASSWORD=""
EMAIL_FROM_EMAIL=""
EMAIL_FROM_NAME="造图台"
EMAIL_REPLY_TO=""
EMAIL_TEST_RECIPIENT=""

# StorageService. local = local disk. oss/cos/s3 all use the S3-compatible protocol (one config for all three).
# For object storage set endpoint/bucket/region + access keys; custom endpoints (OSS/COS/MinIO) usually need path-style.
STORAGE_PROVIDER="local"
STORAGE_LOCAL_BASE_DIR="public/storage"
STORAGE_PUBLIC_BASE_URL=""
STORAGE_GENERATED_PREFIX="generated"
STORAGE_UPLOADS_PREFIX="uploads"
STORAGE_ENDPOINT=""
STORAGE_BUCKET=""
STORAGE_REGION=""
STORAGE_FORCE_PATH_STYLE="false"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""

# OAuth third-party login fallback. Production values are recommended to be saved in Admin Settings.
# Callback URLs: {NEXT_PUBLIC_SITE_URL}/api/auth/oauth/github/callback and .../google/callback
OAUTH_GITHUB_CLIENT_ID=""
OAUTH_GITHUB_CLIENT_SECRET=""
OAUTH_GOOGLE_CLIENT_ID=""
OAUTH_GOOGLE_CLIENT_SECRET=""

# Optional semantic moderation request timeout (ms). Defaults to 15000.
MODERATION_TIMEOUT_MS="15000"
